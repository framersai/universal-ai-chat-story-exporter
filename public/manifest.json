{
  "manifest_version": 3,
  "name": "Wilds AI: Universal AI Chat & Story Exporter",
  "version": "0.2.0",
  "description": "Export your AI companion chats and adventure stories from multiple platforms easily.",
  "permissions": ["downloads"],
  "host_permissions": [
    "https://*.character.ai/*",
    "https://*.characterai.io/*",
    "https://play.aidungeon.com/*",
    "https://api.aidungeon.com/*",
    "https://janitorai.com/*",
    "https://*.janitorai.com/*"
  ],
  "icons": {
    "16": "wilds-logo.png",
    "32": "wilds-logo.png",
    "48": "wilds-logo.png",
    "128": "wilds-logo.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": "wilds-logo.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.character.ai/*",
        "https://play.aidungeon.com/*",
        "https://janitorai.com/*"
      ],
      "js": ["content.js"]
    },
    {
      "matches": ["https://janitorai.com/*"],
      "js": ["janitor-monitor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "wilds-logo.svg",
        "wilds-logo.png",
        "cards/*"
      ],
      "matches": [
        "https://*.character.ai/*",
        "https://play.aidungeon.com/*",
        "https://janitorai.com/*"
      ]
    }
  ]
}
